<UserControl
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="using:ImageFunctions.Gui.ViewModels"
x:Class="ImageFunctions.Gui.Views.LayersImageControl"
x:DataType="vm:LayersImageData"
d:DesignHeight="200"
d:DesignWidth="200"
mc:Ignorable="d">
<Design.DataContext>
	<vm:LayersImageData/>
</Design.DataContext>

<UserControl.Styles>
	<Style Selector="Button">
		<Setter Property="Margin" Value="0,0,0,0"/>
		<Setter Property="Padding" Value="8,8,8,8"/>
	</Style>
	<Style Selector="Image">
		<Setter Property="MaxHeight" Value="120"/>
		<Setter Property="MaxWidth" Value="120"/>
	</Style>
	<Style Selector="Border">
		<Setter Property="Margin" Value="2,2,2,2" /><!-- based on GridSplitter -->
		<Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}"/>
		<Setter Property="BorderThickness" Value="1,1,1,1"/><!-- based on Expander -->
	</Style>
</UserControl.Styles>

<DockPanel>
	<TextBlock DockPanel.Dock="Top" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
	<StackPanel DockPanel.Dock="Left">
		<Button Tag="Move Up" Command="{Binding LayerMoveUp}" IsEnabled="{Binding UpEnabled}">
			<PathIcon Data="{StaticResource IconTriUp}"/>
		</Button>
		<Button Tag="Move Down" Command="{Binding LayerMoveDown}" IsEnabled="{Binding DownEnabled}">
			<PathIcon Data="{StaticResource IconTriDown}"/>
		</Button>
		<!-- <Button Tag="Test" Click="TestClick" Command="{Binding Test}">T</Button> -->
		<Button Tag="Remove Layer" Command="{Binding LayerDelete}">
			<PathIcon Data="{StaticResource IconCardRemove}"/>
		</Button>
	</StackPanel>
	<Grid ColumnDefinitions="*,Auto,*" RowDefinitions="*,Auto,*">
		<Border Grid.Column="1" Grid.Row="1">
			<Image Source="{Binding Image}" Stretch="Uniform" />
		</Border>
	</Grid>
</DockPanel>

</UserControl>