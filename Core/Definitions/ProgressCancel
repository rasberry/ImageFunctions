using Rasberry.Cli;

namespace ImageFunctions.Core;

/// <summary>
/// Interface to pass around progress and cancellation objects
/// </summary>
public interface IProgressCancel
{
	IProgressWithLabel<double> Progress { get; }
	CancellationToken Token { get; }
}

/// <summary>
/// Basic implementation of IProgressCancel
/// </summary>
public struct ProgressCancel : IProgressCancel
{
	public ProgressCancel(IProgressWithLabel<double> progress, CancellationToken token)
	{
		Progress = progress;
		Token = token;
	}

	public IProgressWithLabel<double> Progress { get; init; }
	public CancellationToken Token { get; init; }
}
